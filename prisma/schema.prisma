generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  ADMIN
  CUSTOMER
  TAILOR
  FASHION_HOUSE
}

enum FashionHouseStatus {
  PENDING
  APPROVED
  REJECTED
}

enum OrderStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
}

model User {
  id       Int     @id @default(autoincrement())
  name     String
  email    String  @unique
  password String
  phone    String?
  role     Role

  fashionHouseOwned FashionHouse? @relation("Owner")

  staffProfile    Staff?
  customerProfile Customer? @relation("userCustomer")

  notifications Notification[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model FashionHouse {
  id      Int                @id @default(autoincrement())
  name    String
  address String
  status  FashionHouseStatus @default(PENDING)

  ownerId Int  @unique
  owner   User @relation("Owner", fields: [ownerId], references: [id])

  staff     Staff[]
  customers Customer[]
  orders    Order[]

  createdAt DateTime @default(now())
}

model Staff {
  id Int @id @default(autoincrement())

  userId Int  @unique
  user   User @relation(fields: [userId], references: [id])

  fashionHouseId Int
  fashionHouse   FashionHouse @relation(fields: [fashionHouseId], references: [id])

  role Role

  orders Order[]

  createdAt DateTime @default(now())
}

model Customer {
  id Int @id @default(autoincrement())

  userId Int?  @unique
  user   User? @relation("userCustomer", fields: [userId], references: [id])

  phone String
  email String?

  fashionHouseId Int?
  fashionHouse   FashionHouse? @relation(fields: [fashionHouseId], references: [id])

  measurements Measurement[]
  orders       Order[]

  createdAt DateTime @default(now())
}

model Measurement {
  id Int @id @default(autoincrement())

  customerId Int
  customer   Customer @relation(fields: [customerId], references: [id])

  neck     Float
  chest    Float
  waist    Float
  shoulder Float
  sleeve   Float
  hip      Float
  inseam   Float
  notes    String?
  orders   Order[]

  createdAt DateTime @default(now())
}

model Order {
  id Int @id @default(autoincrement())

  customerId Int
  customer   Customer @relation(fields: [customerId], references: [id])

  tailorId Int?
  tailor   Staff? @relation(fields: [tailorId], references: [id])

  fashionHouseId Int?
  fashionHouse   FashionHouse? @relation(fields: [fashionHouseId], references: [id])

  measurementId Int
  measurement   Measurement @relation(fields: [measurementId], references: [id])

  status     OrderStatus @default(PENDING)
  totalPrice Float

  createdAt DateTime @default(now())
}

model Notification {
  id Int @id @default(autoincrement())

  userId Int
  user   User @relation(fields: [userId], references: [id])

  message String
  read    Boolean @default(false)

  createdAt DateTime @default(now())
}
